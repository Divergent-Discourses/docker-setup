# Default server configuration
#
server {

	# SSL configuration
	#
	# listen 443 ssl default_server;
	# listen [::]:443 ssl default_server;
	#
	# See: https://bugs.debian.org/773332
	#
	# Read up on ssl_ciphers to ensure a secure configuration.
	# See: https://bugs.debian.org/765782
	#
	# Self signed certs generated by the ssl-cert package
	# Don't use them in a production server!
	#
	# include snippets/snakeoil.conf;
	listen 80;
	root /home/vmuser/public;

	# Add index.php to the list if you are using PHP
	#index base.html index.html index.htm index.nginx-debian.html;
	index base.html;
	#server_name tibetcorpus.uni-leipzig.de diverge.uni-leipzig.de;
	server_name localhost;

	client_max_body_size 2000M; # (e.g., 50M for 50 megabytes, or 200M, 1G etc.)

        location = / {
                try_files $uri $uri/ /base.html =404;
        }
	
	location = /images {
        	return 301 /images/;
    	}

    	location /images/ {
        	#alias /home/vmuser/public/image/index.html;
        	alias /home/vmuser/public/image/;
		index index.html;
        	#autoindex on;
        	#autoindex_format html;
        	#default_type text/html;
    	}

    	location /newspaper-images/ {
        	alias /mnt/data/diverge_images/;
        	autoindex on;
        	autoindex_format json;
    	}

    	location = /corpus_analysis {
        	return 301 /corpus_analysis/;
    	}
		 
	location /search/ {
                # First attempt to serve request as file, then
                # as directory, then fall back to displaying a 404.
                proxy_pass http://search:8501/;
                proxy_http_version 1.1;
                proxy_set_header Upgrade $http_upgrade;
                proxy_set_header Connection "upgrade";
                proxy_set_header Host $host;
                proxy_read_timeout 86400;
                proxy_buffering off;
        }

        location /corpus_analysis/ {
                # First attempt to serve request as file, then
                # as directory, then fall back to displaying a 404.
                proxy_pass http://corpus:8503/;
                proxy_http_version 1.1;
                proxy_set_header Upgrade $http_upgrade;
                proxy_set_header Connection "upgrade";
                proxy_set_header Host $http_host;
                proxy_set_header X-Real-IP $remote_addr;
                proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
                proxy_set_header X-Forwarded-Proto $scheme;
                proxy_set_header Origin $http_origin;
                proxy_set_header Referer $http_referer;
                proxy_read_timeout 86400;
                proxy_send_timeout 86400;
                proxy_buffering off;
                proxy_request_buffering off;
                proxy_cache_bypass $http_upgrade;
        }

        location /corpus_api/ {
                proxy_pass http://corpus_api:8505/;
                proxy_http_version 1.1;
                proxy_set_header  Upgrade $http_upgrade;
                proxy_set_header  Connection "upgrade";
                proxy_set_header  Host $host;
                proxy_set_header  X-Real-IP $remote_addr;
                proxy_set_header  X-Forwarded-For $proxy_add_x_forwarded_for;
                proxy_set_header  X-Forwarded-Proto $scheme;
                proxy_read_timeout 86400;
                proxy_send_timeout 86400;
                proxy_buffering off;
	}

}

